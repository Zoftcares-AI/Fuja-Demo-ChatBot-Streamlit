# Cloudflare API token with permission to call your Worker/AI endpoint
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Full URL to your Cloudflare AI Search / Agent endpoint
# Example: https://my-agent.my-subdomain.workers.dev/chat
CLOUDFLARE_AGENT_URL=https://your-worker-url/chat

# Optional: if your endpoint expects account id in payload
CLOUDFLARE_ACCOUNT_ID=

# Optional: override auth header name if your endpoint expects custom header
# Default uses Authorization: Bearer <token>
CLOUDFLARE_AUTH_HEADER=Authorization

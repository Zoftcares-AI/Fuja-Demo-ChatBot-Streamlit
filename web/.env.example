# Set these in Vercel → Project → Settings → Environment Variables (never commit secrets).
# Used only by serverless routes under /api — the browser never sees the token.

CLOUDFLARE_AGENT_URL=https://your-worker.workers.dev/chat
CLOUDFLARE_API_TOKEN=your_token

# Optional (same as Streamlit / cloudflare_client.py)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_HEADER=Authorization
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
